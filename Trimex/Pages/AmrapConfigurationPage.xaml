<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.AmrapConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + time card + presets + button -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="12">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="AMRAP"
                    TextColor="{StaticResource TextPrimary}" />
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansRegular"
                    FontSize="10"
                    HorizontalTextAlignment="Center"
                    Text="AS MANY ROUNDS AS POSSIBLE"
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Carousel Number Picker -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPickerPanUpdated" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Margin="0,0,0,8"
                        Text="MINUTES"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotMinus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        x:Name="PickerSlotMinus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="MinutesNumberLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="52"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource AccentRed}" />
                    <Label
                        x:Name="PickerSlotPlus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotPlus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        Margin="0,8,0,0"
                        Text="SWIPE UP OR DOWN"
                        TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Presets + Intensity Bar -->
            <VerticalStackLayout Grid.Row="2" Spacing="8">

                <!-- 4-col Preset Grid -->
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <Button
                        x:Name="Preset5"
                        Grid.Column="0"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="5"
                        CornerRadius="12"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        HeightRequest="52"
                        Text="5:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Preset10"
                        Grid.Column="1"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="10"
                        CornerRadius="12"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        HeightRequest="52"
                        Text="10:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Preset15"
                        Grid.Column="2"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="15"
                        CornerRadius="12"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        HeightRequest="52"
                        Text="15:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Preset20"
                        Grid.Column="3"
                        BackgroundColor="{StaticResource AccentBlue}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="20"
                        CornerRadius="12"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        HeightRequest="52"
                        Text="20:00"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>

                <!-- Intensity Bar -->
                <Border
                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                    Padding="14,10"
                    Stroke="Transparent"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                        <BoxView
                            Grid.Column="0"
                            BackgroundColor="{StaticResource AccentRed}"
                            CornerRadius="2"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="9"
                                Text="ESTIMATED INTENSITY"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="IntensityLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                Text="HIGH PERFORMANCE"
                                TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!-- START WORKOUT -->
            <Button
                Grid.Row="3"
                BackgroundColor="#CAFD00"
                Clicked="OnStartClicked"
                CornerRadius="14"
                FontFamily="OpenSansSemibold"
                FontSize="16"
                HeightRequest="52"
                Text="START WORKOUT"
                ImageSource="rayb.png"
                ContentLayout="Right, 8"
                TextColor="#000000" />

        </Grid>
    </Grid>
</ContentPage>
