<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.DeathByEmomTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <Grid
        Padding="24,20,24,24"
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label x:Name="WorkoutTitleLabel" Style="{StaticResource PageTitleStyle}" />
            <Label x:Name="WorkoutContextLabel" Style="{StaticResource HeroSubtitleStyle}" />
        </VerticalStackLayout>

        <!-- Main area -->
        <Grid Grid.Row="1">
            <VerticalStackLayout Spacing="16" VerticalOptions="Center">

                <!-- Round indicator -->
                <Label
                    x:Name="RoundLabel"
                    FontFamily="OpenSansSemibold"
                    FontSize="20"
                    HorizontalTextAlignment="Center"
                    TextColor="{StaticResource AccentRed}" />

                <!-- Circle timer -->
                <Grid
                    HeightRequest="320"
                    HorizontalOptions="Center"
                    WidthRequest="320">
                    <controls:CircularProgressView x:Name="ProgressRing" />

                    <Grid
                        x:Name="TimerDisplayLayout"
                        HeightRequest="220"
                        HorizontalOptions="Center"
                        IsVisible="False"
                        VerticalOptions="Center"
                        WidthRequest="220">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStateTapped" />
                        </Grid.GestureRecognizers>
                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="4"
                            VerticalOptions="Center">
                            <Label
                                x:Name="StateValueLabel"
                                FontSize="46"
                                MaxLines="1"
                                Style="{StaticResource TimerValueStyle}" />
                            <Label
                                x:Name="StateHintLabel"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Style="{StaticResource HeroSubtitleStyle}" />
                            <ImageButton
                                x:Name="PauseActionButton"
                                Padding="0"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Clicked="OnTimerActionClicked"
                                HeightRequest="112"
                                HorizontalOptions="Center"
                                IsVisible="True"
                                Margin="0,8,0,0"
                                Source="pause.png"
                                VerticalOptions="Center"
                                WidthRequest="112" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid
                        x:Name="CenterActionShell"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        HeightRequest="320"
                        WidthRequest="320">
                        <Image
                            x:Name="TimerActionImage"
                            Aspect="AspectFit"
                            HeightRequest="450"
                            HorizontalOptions="Center"
                            InputTransparent="True"
                            Source="play.png"
                            VerticalOptions="Center"
                            WidthRequest="450" />
                        <ImageButton
                            x:Name="TimerActionButton"
                            Padding="0"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="OnTimerActionClicked"
                            HeightRequest="320"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            WidthRequest="320" />
                    </Grid>
                </Grid>

            </VerticalStackLayout>
        </Grid>

        <!-- Slide to end -->
        <controls:SlideToEndView
            Grid.Row="2"
            x:Name="SlideToEnd"
            SlideCompleted="OnSlideCompleted" />
    </Grid>
</ContentPage>
