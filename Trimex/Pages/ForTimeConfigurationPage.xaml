<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.ForTimeConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="FOR TIME"
    BackgroundColor="Black">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + time card + pills + button -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="12">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="FOR TIME"
                    TextColor="{StaticResource TextPrimary}" />
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansRegular"
                    FontSize="10"
                    HorizontalTextAlignment="Center"
                    Text="AS FAST AS YOU CAN"
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Time Limit Card -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTimeCapTapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="6" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Text="TIME LIMIT"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="TimeCapDisplayLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="52"
                        HorizontalTextAlignment="Center"
                        Text="15:00"
                        TextColor="{StaticResource AccentRed}" />
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        Text="TAP TO CHANGE"
                        TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Quick select pills + help text -->
            <VerticalStackLayout Grid.Row="2" Spacing="8">
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansSemibold"
                    FontSize="9"
                    HorizontalTextAlignment="Center"
                    Text="QUICK SELECT"
                    TextColor="{StaticResource TextSecondary}" />
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Button
                        x:Name="Pill5"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="5"
                        CornerRadius="20"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HeightRequest="36"
                        Padding="14,0"
                        Text="5:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Pill10"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="10"
                        CornerRadius="20"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HeightRequest="36"
                        Padding="14,0"
                        Text="10:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Pill15"
                        BackgroundColor="{StaticResource AccentRed}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="15"
                        CornerRadius="20"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HeightRequest="36"
                        Padding="14,0"
                        Text="15:00"
                        TextColor="{StaticResource TextPrimary}" />
                    <Button
                        x:Name="Pill20"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        Clicked="OnQuickSelectClicked"
                        CommandParameter="20"
                        CornerRadius="20"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HeightRequest="36"
                        Padding="14,0"
                        Text="20:00"
                        TextColor="{StaticResource TextPrimary}" />
                </HorizontalStackLayout>
                <Label
                    FontFamily="OpenSansRegular"
                    FontSize="11"
                    HorizontalTextAlignment="Center"
                    Text="Select 0 min in the picker for a manual stop with no cap."
                    TextColor="{StaticResource MutedText}" />
            </VerticalStackLayout>

            <!-- START WORKOUT -->
            <Button
                Grid.Row="3"
                BackgroundColor="#CAFD00"
                Clicked="OnStartClicked"
                CornerRadius="14"
                FontFamily="OpenSansSemibold"
                FontSize="16"
                HeightRequest="52"
                Text="START WORKOUT ⚡"
                TextColor="#000000" />

        </Grid>

        <!--  Floating overlay for time selection  -->
        <Grid
            x:Name="TimeCapOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Time Limit"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="TimeCapItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
