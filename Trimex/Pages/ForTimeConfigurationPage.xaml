<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.ForTimeConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="FOR TIME"
    BackgroundColor="Black">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!--  Main content  -->
        <ScrollView>
            <VerticalStackLayout Padding="24,24,24,40" Spacing="18">
                <Label Style="{StaticResource PageTitleStyle}" Text="FOR TIME" />

                <Label Style="{StaticResource HeroSubtitleStyle}" Text="As fast as you can." />

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Label Style="{StaticResource SectionTitleStyle}" Text="Hero WOD" />

                        <Picker
                            x:Name="HeroWodPicker"
                            Title="Choose a saved hero WOD (optional)"
                            SelectedIndexChanged="OnHeroWodSelectionChanged" />

                        <Label
                            x:Name="HeroWodEmptyLabel"
                            IsVisible="False"
                            Style="{StaticResource MutedCaptionStyle}"
                            Text="No FOR TIME hero WODs are stored yet in SQLite." />

                        <Border
                            x:Name="HeroDescriptionBorder"
                            Padding="14"
                            IsVisible="False"
                            Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Style="{StaticResource SectionTitleStyle}" Text="Workout description" />
                                <Label x:Name="HeroDescriptionLabel" Style="{StaticResource MutedCaptionStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Label Style="{StaticResource SectionTitleStyle}" Text="TIME LIMIT" />
                        <Border
                            Padding="14"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTimeCapTapped" />
                            </Border.GestureRecognizers>
                            <Label
                                x:Name="TimeCapDisplayLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalTextAlignment="Center"
                                Text="15 minutes"
                                TextColor="{StaticResource TextPrimary}" />
                        </Border>
                        <Label Style="{StaticResource MutedCaptionStyle}" Text="Select 0 minutes if you want a manual stop with no cap." />
                    </VerticalStackLayout>
                </Border>

                <Button
                    Clicked="OnStartClicked"
                    Style="{StaticResource AccentButtonStyle}"
                    Text="START" />
            </VerticalStackLayout>
        </ScrollView>

        <!--  Floating overlay for time selection  -->
        <Grid
            x:Name="TimeCapOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Time Limit"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="TimeCapItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
