<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid
        Padding="24,20,24,24"
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label x:Name="WorkoutTitleLabel" Style="{StaticResource PageTitleStyle}" />
            <Label x:Name="WorkoutContextLabel" Style="{StaticResource HeroSubtitleStyle}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <Grid x:Name="ConfettiOverlay" InputTransparent="True" />

            <VerticalStackLayout Spacing="22" VerticalOptions="Center">
                <Grid
                    HeightRequest="320"
                    HorizontalOptions="Center"
                    WidthRequest="320">
                    <controls:CircularProgressView x:Name="ProgressRing" />

                    <Grid
                        x:Name="TimerDisplayLayout"
                        HeightRequest="220"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="220">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStateTapped" />
                        </Grid.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="4"
                            VerticalOptions="Center">
                            <Label
                                x:Name="StateValueLabel"
                                FontSize="46"
                                MaxLines="1"
                                Style="{StaticResource TimerValueStyle}" />

                            <Label
                                x:Name="StateHintLabel"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                Style="{StaticResource HeroSubtitleStyle}" />

                            <Label
                                x:Name="PausedTimeLabel"
                                HorizontalTextAlignment="Center"
                                IsVisible="False"
                                LineBreakMode="NoWrap"
                                MaxLines="1"
                                Style="{StaticResource ValueTextStyle}" />

                            <ImageButton
                                x:Name="PauseActionButton"
                                Padding="0"
                                Aspect="AspectFit"
                                BackgroundColor="Transparent"
                                Clicked="OnTimerActionClicked"
                                HeightRequest="112"
                                HorizontalOptions="Center"
                                IsVisible="False"
                                Margin="0,8,0,0"
                                Source="pause.png"
                                VerticalOptions="Center"
                                WidthRequest="112" />
                        </VerticalStackLayout>
                    </Grid>

                    <ImageButton
                        x:Name="TimerActionButton"
                        Padding="0"
                        Aspect="AspectFit"
                        BackgroundColor="Transparent"
                        Clicked="OnTimerActionClicked"
                        HeightRequest="156"
                        HorizontalOptions="Center"
                        Source="play.png"
                        VerticalOptions="Center"
                        WidthRequest="156" />
                </Grid>

                <VerticalStackLayout
                    x:Name="RoundSection"
                    IsVisible="False"
                    Spacing="12">
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="How many rounds?" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Button
                            Clicked="OnRoundClicked"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Text="ROUND" />
                        <Label
                            x:Name="RoundCountLabel"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource CounterBadgeStyle}"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <Button
            Grid.Row="2"
            Clicked="OnEndClicked"
            Style="{StaticResource GhostButtonStyle}"
            Text="End workout" />
    </Grid>
</ContentPage>
