<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid
        Padding="24,20,24,24"
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label x:Name="WorkoutTitleLabel" Style="{StaticResource PageTitleStyle}" />
            <Label x:Name="WorkoutContextLabel" Style="{StaticResource HeroSubtitleStyle}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <Grid x:Name="ConfettiOverlay" InputTransparent="True" />

            <VerticalStackLayout Spacing="22" VerticalOptions="Center">
                <Grid
                    HeightRequest="320"
                    HorizontalOptions="Center"
                    WidthRequest="320">
                    <controls:CircularProgressView x:Name="ProgressRing" />

                    <VerticalStackLayout
                        x:Name="TimerDisplayLayout"
                        HorizontalOptions="Center"
                        Spacing="8"
                        VerticalOptions="Center">
                        <Label x:Name="StateValueLabel" Style="{StaticResource TimerValueStyle}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStateTapped" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label x:Name="StateHintLabel" Style="{StaticResource HeroSubtitleStyle}" />

                        <Label
                            x:Name="PausedTimeLabel"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            Style="{StaticResource ValueTextStyle}" />
                    </VerticalStackLayout>

                    <Button
                        x:Name="TimerActionButton"
                        Clicked="OnTimerActionClicked"
                        HorizontalOptions="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Text="PLAY"
                        VerticalOptions="Center"
                        WidthRequest="120" />
                </Grid>

                <VerticalStackLayout
                    x:Name="RoundSection"
                    IsVisible="False"
                    Spacing="12">
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="How many rounds?" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Button
                            Clicked="OnRoundClicked"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Text="ROUND" />
                        <Label
                            x:Name="RoundCountLabel"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource CounterBadgeStyle}"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <Button
            Grid.Row="2"
            Clicked="OnEndClicked"
            Style="{StaticResource GhostButtonStyle}"
            Text="End workout" />
    </Grid>
</ContentPage>
