<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid
        Padding="24,20,24,24"
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,*,Auto">

        <VerticalStackLayout
            Grid.Row="0"
            HorizontalOptions="Center"
            Spacing="10">
            <Label
                x:Name="WorkoutTitleLabel"
                CharacterSpacing="1.2"
                FontSize="39"
                HorizontalTextAlignment="Center"
                Style="{StaticResource PageTitleStyle}" />
            <Label
                x:Name="WorkoutContextLabel"
                CharacterSpacing="2.5"
                FontSize="14"
                LineBreakMode="TailTruncation"
                MaxLines="1"
                Style="{StaticResource HeroSubtitleStyle}" />

            <Border
                x:Name="WorkoutDetailsContainer"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                IsVisible="False"
                MaximumHeightRequest="120"
                Padding="12,8"
                Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <ScrollView VerticalScrollBarVisibility="Always">
                    <Label
                        x:Name="WorkoutDetailsLabel"
                        FontSize="14"
                        LineBreakMode="WordWrap"
                        Style="{StaticResource HeroSubtitleStyle}" />
                </ScrollView>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <Border
                BackgroundColor="{StaticResource AccentNeonYellow}"
                HeightRequest="280"
                HorizontalOptions="Start"
                Opacity="0.06"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 140"
                TranslationX="-120"
                TranslationY="-120"
                VerticalOptions="Start"
                WidthRequest="280" />

            <Border
                BackgroundColor="{StaticResource AccentBlue}"
                HeightRequest="220"
                HorizontalOptions="End"
                Opacity="0.06"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 110"
                TranslationX="90"
                TranslationY="120"
                VerticalOptions="Center"
                WidthRequest="220" />

            <Grid
                InputTransparent="True"
                ColumnDefinitions="35*,30*,35*"
                RowDefinitions="35*,30*,35*">
                <Label
                    x:Name="WorkoutMinutesWatermarkLabel"
                    Grid.Row="0"
                    Grid.Column="2"
                    FontFamily="OpenSansSemibold"
                    FontSize="96"
                    HorizontalOptions="End"
                    HorizontalTextAlignment="End"
                    Margin="0,8,0,0"
                    Opacity="0.5"
                    TextColor="{StaticResource TextPrimary}"
                    VerticalOptions="Start"
                    VerticalTextAlignment="Start" />

                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    FontFamily="OpenSansSemibold"
                    FontSize="52"
                    HorizontalOptions="Start"
                    HorizontalTextAlignment="Start"
                    Margin="0,0,0,8"
                    Opacity="0.5"
                    Text="MIN"
                    TextColor="{StaticResource TextPrimary}"
                    VerticalOptions="End"
                    VerticalTextAlignment="End" />
            </Grid>

            <VerticalStackLayout
                Spacing="24"
                VerticalOptions="Center">
                <Grid
                    HeightRequest="336"
                    HorizontalOptions="Center"
                    WidthRequest="336">
                    <Border
                        BackgroundColor="Transparent"
                        HeightRequest="320"
                        HorizontalOptions="Center"
                        Stroke="{StaticResource SurfaceContainerHighest}"
                        StrokeShape="RoundRectangle 160"
                        StrokeThickness="2"
                        VerticalOptions="Center"
                        WidthRequest="320" />

                    <controls:CircularProgressView x:Name="ProgressRing" />

                    <Border
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="224"
                        HorizontalOptions="Center"
                        Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 112"
                        StrokeThickness="1"
                        VerticalOptions="Center"
                        WidthRequest="224">

                        <Grid
                            x:Name="TimerDisplayLayout"
                            HeightRequest="220"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            WidthRequest="220">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStateTapped" />
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                Spacing="4"
                                VerticalOptions="Center">
                                <Label
                                    x:Name="StateValueLabel"
                                    FontSize="50"
                                    MaxLines="1"
                                    Style="{StaticResource TimerValueStyle}" />

                                <Label
                                    x:Name="StateHintLabel"
                                    CharacterSpacing="1.8"
                                    FontSize="12"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Style="{StaticResource HeroSubtitleStyle}" />

                                <Label
                                    x:Name="PausedTimeLabel"
                                    HorizontalTextAlignment="Center"
                                    IsVisible="False"
                                    LineBreakMode="NoWrap"
                                    MaxLines="1"
                                    Style="{StaticResource ValueTextStyle}" />

                                <ImageButton
                                    x:Name="PauseActionButton"
                                    Padding="0"
                                    Aspect="AspectFit"
                                    BackgroundColor="Transparent"
                                    Clicked="OnTimerActionClicked"
                                    HeightRequest="112"
                                    HorizontalOptions="Center"
                                    IsVisible="False"
                                    Margin="0,8,0,0"
                                    Source="pause.png"
                                    VerticalOptions="Center"
                                    WidthRequest="112" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border
                        x:Name="CenterActionShell"
                        BackgroundColor="{StaticResource SurfaceContainerHighest}"
                        HeightRequest="196"
                        HorizontalOptions="Center"
                        Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 98"
                        StrokeThickness="1"
                        VerticalOptions="Center"
                        WidthRequest="196">

                        <ImageButton
                            x:Name="TimerActionButton"
                            Padding="0"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="OnTimerActionClicked"
                            HeightRequest="136"
                            HorizontalOptions="Center"
                            Source="play.png"
                            VerticalOptions="Center"
                            WidthRequest="136" />
                    </Border>
                </Grid>

                <VerticalStackLayout
                    x:Name="RoundSection"
                    IsVisible="False"
                    Spacing="0">
                    <Border
                        BackgroundColor="{StaticResource SurfaceContainerLow}"
                        Padding="16"
                        Stroke="{StaticResource BorderColor}"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1">

                        <VerticalStackLayout Spacing="12">
                            <Label
                                CharacterSpacing="2"
                                HorizontalTextAlignment="Center"
                                Style="{StaticResource MutedCaptionStyle}"
                                Text="ROUNDS" />

                            <Button
                                x:Name="RoundButton"
                                BackgroundColor="{StaticResource AccentGreen}"
                                Clicked="OnRoundClicked"
                                CornerRadius="56"
                                FontAttributes="Bold"
                                FontSize="34"
                                HeightRequest="112"
                                HorizontalOptions="Center"
                                IsEnabled="False"
                                Text="0"
                                TextColor="{StaticResource TextPrimary}"
                                WidthRequest="112">
                                <Button.Shadow>
                                    <Shadow
                                        Brush="{StaticResource AccentGreen}"
                                        Offset="0,0"
                                        Opacity="0.75"
                                        Radius="20" />
                                </Button.Shadow>
                            </Button>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <controls:SlideToEndView
            Grid.Row="2"
            x:Name="SlideToReset"
            SlideCompleted="OnSlideResetCompleted"
            TrackText="Slide to reset" />

        <Grid
            x:Name="ConfettiOverlay"
            Grid.RowSpan="3"
            InputTransparent="True" />
    </Grid>
</ContentPage>
