<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <Grid
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ═══ Row 0 · Top Navigation Bar ═══ -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="48,*,48"
            HeightRequest="64"
            Padding="16,0">


            <Label
                Grid.Column="1"
                FontAttributes="Bold,Italic"
                FontFamily="OpenSansSemibold"
                FontSize="20"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="TRIMEX"
                TextColor="{StaticResource AccentNeonYellow}"
                VerticalOptions="Center" />

            <Button
                x:Name="DetailsButton"
                Grid.Column="2"
                BackgroundColor="Transparent"
                Clicked="OnDetailsClicked"
                CornerRadius="20"
                FontSize="20"
                HeightRequest="40"
                HorizontalOptions="Center"
                Padding="0"
                Text="⚙"
                TextColor="{StaticResource TextSecondary}"
                VerticalOptions="Center"
                WidthRequest="40" />
        </Grid>

        <!-- ═══ Row 1 · Title + Subtitle ═══ -->
        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Padding="24,0"
            Spacing="4">

            <Label
                x:Name="WorkoutTitleLabel"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                FontSize="48"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource TextPrimary}" />

            <Grid
                ColumnDefinitions="32,Auto,32"
                ColumnSpacing="12"
                HorizontalOptions="Center">

                <BoxView
                    Color="{StaticResource AccentNeonYellow}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0."
                    VerticalOptions="Center" />

                <Label
                    x:Name="WorkoutContextLabel"
                    Grid.Column="1"
                    CharacterSpacing="3"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"
                    TextColor="{StaticResource TextSecondary}" />

                <BoxView
                    Grid.Column="2"
                    Color="{StaticResource AccentNeonYellow}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center" />
            </Grid>

            <Border
                x:Name="WorkoutDetailsContainer"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                IsVisible="False"
                Margin="0,8,0,0"
                MaximumHeightRequest="120"
                Padding="14,10"
                Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">

                <ScrollView VerticalScrollBarVisibility="Never">
                    <Label
                        x:Name="WorkoutDetailsLabel"
                        FontSize="14"
                        LineBreakMode="WordWrap"
                        TextColor="{StaticResource TextSecondary}" />
                </ScrollView>
            </Border>
        </VerticalStackLayout>

        <!-- ═══ Watermark "15" — top-right screen corner ═══ -->
        <Label
            x:Name="WorkoutMinutesWatermarkLabel"
            Grid.Row="0"
            Grid.RowSpan="5"
            FontAttributes="Bold"
            FontFamily="OpenSansSemibold"
            FontSize="300"
            HorizontalOptions="End"
            InputTransparent="True"
            Margin="0,0,10,0"
            Opacity="0.02"
            TextColor="{StaticResource TextPrimary}"
            VerticalOptions="Start" />

        <!-- ═══ Watermark "MIN" — bottom-left screen corner ═══ -->
        <Label
            Grid.Row="0"
            Grid.RowSpan="5"
            FontAttributes="Bold"
            FontFamily="OpenSansSemibold"
            FontSize="150"
            HorizontalOptions="Start"
            InputTransparent="True"
            Margin="10,0,20,100"
            Opacity="0.02"
            Text="MIN"
            TextColor="{StaticResource TextPrimary}"
            VerticalOptions="End" />

        <!-- ═══ Row 2 · Central Timer (star row — centered) ═══ -->
        <Grid
            Grid.Row="2"
            Padding="24,0">

            <!-- Timer ring assembly -->
            <Grid
                HeightRequest="340"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="340">

                <!-- Progress ring -->
                <controls:CircularProgressView
                    x:Name="ProgressRing"
                    AccentColor="{StaticResource AccentNeonYellow}"
                    HeightRequest="330"
                    HorizontalOptions="Center"
                    TrackColor="{StaticResource SurfaceContainerHighest}"
                    VerticalOptions="Center"
                    WidthRequest="330" />

                <!-- Timer display (centered inside progress ring) -->
                <Grid
                    x:Name="TimerDisplayLayout"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStateTapped" />
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="4"
                        VerticalOptions="Center">

                        <Label
                            x:Name="StateValueLabel"
                            FontSize="40"
                            MaxLines="1"
                            Style="{StaticResource TimerValueStyle}" />

                        <Label
                            x:Name="StateHintLabel"
                            CharacterSpacing="1.5"
                            FontSize="11"
                            LineBreakMode="TailTruncation"
                            MaxLines="1"
                            Style="{StaticResource HeroSubtitleStyle}" />

                        <Label
                            x:Name="PausedTimeLabel"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            LineBreakMode="NoWrap"
                            MaxLines="1"
                            Style="{StaticResource ValueTextStyle}" />

                        <ImageButton
                            x:Name="PauseActionButton"
                            Padding="0"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="OnTimerActionClicked"
                            CornerRadius="85"
                            HeightRequest="169"
                            HorizontalOptions="Center"
                            IsVisible="False"
                            Source="pause.png"
                            VerticalOptions="Center"
                            WidthRequest="169" />
                    </VerticalStackLayout>
                </Grid>
                

                <!-- Play button (Idle / Paused) — no background circle -->
                <Grid
                    x:Name="CenterActionShell"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <Image
                        x:Name="TimerActionImage"
                        Aspect="AspectFit"
                        HeightRequest="450"
                        HorizontalOptions="Center"
                        InputTransparent="True"
                        Source="play.png"
                        VerticalOptions="Center"
                        WidthRequest="450" />

                    <ImageButton
                        x:Name="TimerActionButton"
                        Padding="0"
                        Aspect="AspectFit"
                        BackgroundColor="Transparent"
                        Clicked="OnTimerActionClicked"
                        CornerRadius="137"
                        HeightRequest="274"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="274" />
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ Row 3 · Metrics Grid ═══ -->
        <Grid
            Grid.Row="3"
            Padding="24,0">

            <VerticalStackLayout
                x:Name="RoundSection"
                IsVisible="False"
                Spacing="0">

                <Border
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="20"
                    Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="1">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            CharacterSpacing="2"
                            FontSize="10"
                            Style="{StaticResource MutedCaptionStyle}"
                            Text="ROUNDS" />

                        <HorizontalStackLayout Spacing="4" VerticalOptions="End">
                            <Button
                                x:Name="RoundButton"
                                BackgroundColor="Transparent"
                                Clicked="OnRoundClicked"
                                CornerRadius="0"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="30"
                                HeightRequest="42"
                                HorizontalOptions="Start"
                                IsEnabled="False"
                                MinimumWidthRequest="0"
                                Padding="0"
                                Text="00"
                                TextColor="{StaticResource TextPrimary}" />

                            <Label
                                FontSize="12"
                                Style="{StaticResource MutedCaptionStyle}"
                                Text="TOTAL"
                                VerticalTextAlignment="End" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ═══ Row 4 · Slide to Reset ═══ -->
        <controls:SlideToEndView
            Grid.Row="4"
            x:Name="SlideToReset"
            Margin="24,16,24,32"
            SlideCompleted="OnSlideResetCompleted"
            TrackText="SLIDE TO RESET" />

        <!-- ═══ Confetti overlay ═══ -->
        <Grid
            x:Name="ConfettiOverlay"
            Grid.RowSpan="5"
            InputTransparent="True" />
    </Grid>
</ContentPage>
