<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid
        Padding="24,20,24,24"
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label x:Name="WorkoutTitleLabel" Style="{StaticResource PageTitleStyle}" />
            <Label x:Name="WorkoutContextLabel" Style="{StaticResource HeroSubtitleStyle}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <Grid x:Name="ConfettiOverlay" InputTransparent="True" />

            <VerticalStackLayout Spacing="22" VerticalOptions="Center">
                <Grid
                    HeightRequest="320"
                    HorizontalOptions="Center"
                    WidthRequest="320">
                    <controls:CircularProgressView x:Name="ProgressRing" />

                    <VerticalStackLayout
                        x:Name="TimerDisplayLayout"
                        HorizontalOptions="Center"
                        Spacing="8"
                        VerticalOptions="Center">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStateTapped" />
                        </VerticalStackLayout.GestureRecognizers>

                        <Label x:Name="StateValueLabel" Style="{StaticResource TimerValueStyle}"></Label>

                        <Label x:Name="StateHintLabel" Style="{StaticResource HeroSubtitleStyle}"></Label>

                        <Label
                            x:Name="PausedTimeLabel"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            Style="{StaticResource ValueTextStyle}" />

                        <ImageButton
                            x:Name="PauseActionButton"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="OnTimerActionClicked"
                            HeightRequest="52"
                            HorizontalOptions="Center"
                            IsVisible="False"
                            Padding="0"
                            Source="pause.png"
                            VerticalOptions="Center"
                            WidthRequest="52" />
                    </VerticalStackLayout>

                    <ImageButton
                        x:Name="TimerActionButton"
                        Aspect="AspectFit"
                        BackgroundColor="Transparent"
                        Clicked="OnTimerActionClicked"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        Padding="0"
                        Source="play.png"
                        VerticalOptions="Center"
                        WidthRequest="72" />
                </Grid>

                <VerticalStackLayout
                    x:Name="RoundSection"
                    IsVisible="False"
                    Spacing="12">
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource SectionTitleStyle}"
                        Text="How many rounds?" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Button
                            Clicked="OnRoundClicked"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Text="ROUND" />
                        <Label
                            x:Name="RoundCountLabel"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource CounterBadgeStyle}"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <Button
            Grid.Row="2"
            Clicked="OnEndClicked"
            Style="{StaticResource GhostButtonStyle}"
            Text="End workout" />
    </Grid>
</ContentPage>
