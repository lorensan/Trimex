<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.WorkoutTimerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <Grid BackgroundColor="{StaticResource AppBackground}" RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!--  ═══ Row 0 · Top Navigation Bar ═══  -->
        <Grid
            Grid.Row="0"
            Padding="16,0"
            ColumnDefinitions="48,*,48"
            HeightRequest="64">


            <Label
                Grid.Column="1"
                FontAttributes="Bold,Italic"
                FontFamily="OpenSansSemibold"
                FontSize="20"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="TRIMEX"
                TextColor="{StaticResource AccentNeonYellow}"
                VerticalOptions="Center" />
        </Grid>

        <!--  ═══ Row 1 · Title + Subtitle ═══  -->
        <VerticalStackLayout
            Grid.Row="1"
            Padding="24,0"
            HorizontalOptions="Center"
            Spacing="4">

            <Label
                x:Name="WorkoutTitleLabel"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                FontSize="48"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource TextPrimary}" />

            <Grid
                ColumnDefinitions="32,Auto,32"
                ColumnSpacing="12"
                HorizontalOptions="Center">

                <BoxView
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0."
                    VerticalOptions="Center"
                    Color="{StaticResource AccentNeonYellow}" />

                <Label
                    x:Name="WorkoutContextLabel"
                    Grid.Column="1"
                    CharacterSpacing="3"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"
                    TextColor="{StaticResource TextSecondary}" />

                <BoxView
                    Grid.Column="2"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center"
                    Color="{StaticResource AccentNeonYellow}" />
            </Grid>

            <Border
                x:Name="WorkoutDetailsContainer"
                Margin="0,8,0,0"
                Padding="14,10"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                IsVisible="False"
                MaximumHeightRequest="120"
                Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">

                <ScrollView VerticalScrollBarVisibility="Never">
                    <Label
                        x:Name="WorkoutDetailsLabel"
                        FontSize="14"
                        LineBreakMode="WordWrap"
                        TextColor="{StaticResource TextSecondary}" />
                </ScrollView>
            </Border>
        </VerticalStackLayout>

        <!--  ═══ Watermark "15" — top-right screen corner ═══  -->
        <Label
            x:Name="WorkoutMinutesWatermarkLabel"
            Grid.Row="0"
            Grid.RowSpan="5"
            Margin="0,0,10,0"
            FontAttributes="Bold"
            FontFamily="OpenSansSemibold"
            FontSize="300"
            HorizontalOptions="End"
            InputTransparent="True"
            Opacity="0.02"
            TextColor="{StaticResource TextPrimary}"
            VerticalOptions="Start" />

        <!--  ═══ Watermark "MIN" — bottom-left screen corner ═══  -->
        <Label
            Grid.Row="0"
            Grid.RowSpan="5"
            Margin="10,0,20,100"
            FontAttributes="Bold"
            FontFamily="OpenSansSemibold"
            FontSize="150"
            HorizontalOptions="Start"
            InputTransparent="True"
            Opacity="0.02"
            Text="MIN"
            TextColor="{StaticResource TextPrimary}"
            VerticalOptions="End" />

        <!--  ═══ Row 2 · Central Timer (star row — centered) ═══  -->
        <Grid Grid.Row="2" Padding="24,0">

            <!--  Timer ring assembly  -->
            <Grid
                HeightRequest="340"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="340">

                <!--  Progress ring  -->
                <controls:CircularProgressView
                    x:Name="ProgressRing"
                    AccentColor="{StaticResource AccentNeonYellow}"
                    HeightRequest="330"
                    HorizontalOptions="Center"
                    TrackColor="{StaticResource SurfaceContainerHighest}"
                    VerticalOptions="Center"
                    WidthRequest="330" />

                <!--  Timer display (centered inside progress ring)  -->
                <Grid
                    x:Name="TimerDisplayLayout"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStateTapped" />
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="4"
                        VerticalOptions="Center">

                        <Label
                            x:Name="StateValueLabel"
                            FontSize="40"
                            MaxLines="1"
                            Style="{StaticResource TimerValueStyle}" />

                        <Label
                            x:Name="StateHintLabel"
                            CharacterSpacing="1.5"
                            FontSize="11"
                            LineBreakMode="TailTruncation"
                            MaxLines="1"
                            Style="{StaticResource HeroSubtitleStyle}" />

                        <Label
                            x:Name="PausedTimeLabel"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            LineBreakMode="NoWrap"
                            MaxLines="1"
                            Style="{StaticResource ValueTextStyle}" />

                        <ImageButton
                            x:Name="PauseActionButton"
                            Padding="0"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="OnTimerActionClicked"
                            CornerRadius="85"
                            HeightRequest="169"
                            HorizontalOptions="Center"
                            IsVisible="False"
                            Source="pause.png"
                            VerticalOptions="Center"
                            WidthRequest="169" />
                    </VerticalStackLayout>
                </Grid>


                <!--  Play button (Idle / Paused) — no background circle  -->
                <Grid
                    x:Name="CenterActionShell"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <Image
                        x:Name="TimerActionImage"
                        Aspect="AspectFit"
                        HeightRequest="450"
                        HorizontalOptions="Center"
                        InputTransparent="True"
                        Source="play.png"
                        VerticalOptions="Center"
                        WidthRequest="450" />

                    <ImageButton
                        x:Name="TimerActionButton"
                        Padding="0"
                        Aspect="AspectFit"
                        BackgroundColor="Transparent"
                        Clicked="OnTimerActionClicked"
                        CornerRadius="137"
                        HeightRequest="274"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="274" />
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ Row 3 · Metrics Grid ═══ -->
        <Grid
            Grid.Row="3"
            Padding="24,0">

            <VerticalStackLayout
                x:Name="RoundSection"
                IsVisible="False"
                Spacing="8"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <Label
                    CharacterSpacing="2"
                    FontSize="10"
                    Style="{StaticResource MutedCaptionStyle}"
                    Text="ROUNDS"
                    TextColor="{StaticResource AccentNeonYellow}"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Center" />

                <Border
                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                    HeightRequest="120"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 60"
                    WidthRequest="120">
                    <Button
                        x:Name="RoundButton"
                        Padding="0"
                        BackgroundColor="Transparent"
                        Clicked="OnRoundClicked"
                        CornerRadius="60"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="30"
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        IsEnabled="False"
                        MinimumWidthRequest="0"
                        Text="00"
                        TextColor="{StaticResource AccentNeonYellow}"
                        VerticalOptions="Center"
                        WidthRequest="120" />
                </Border>

                <Label
                    FontSize="12"
                    Style="{StaticResource MutedCaptionStyle}"
                    Text="TOTAL"
                    TextColor="{StaticResource AccentNeonYellow}"
                    VerticalTextAlignment="Center"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!--  ═══ Row 4 · Slide to Reset ═══  -->
        <controls:SlideToEndView
            x:Name="SlideToReset"
            Grid.Row="4"
            Margin="24,16,24,32"
            SlideCompleted="OnSlideResetCompleted"
            TrackText="SLIDE TO RESET" />

        <!--  ═══ Confetti overlay ═══  -->
        <Grid
            x:Name="ConfettiOverlay"
            Grid.RowSpan="5"
            InputTransparent="True" />

        <!--  ═══ Post-WOD save modal overlay ═══  -->
        <BoxView
            x:Name="SaveModalDimmer"
            Grid.RowSpan="5"
            Color="#CC000000"
            IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSaveModalDimmerTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border
            x:Name="SaveModalContainer"
            Grid.RowSpan="5"
            Margin="24"
            Padding="20"
            BackgroundColor="{StaticResource Surface}"
            HorizontalOptions="Center"
            IsVisible="False"
            StrokeShape="RoundRectangle 20"
            Stroke="{StaticResource BorderColor}"
            StrokeThickness="1"
            VerticalOptions="Center"
            MaximumWidthRequest="400">
            <VerticalStackLayout Spacing="16">
                <Label
                    Text="SAVE RESULT"
                    FontFamily="OpenSansSemibold"
                    FontSize="20"
                    TextColor="{StaticResource AccentNeonYellow}"
                    HorizontalTextAlignment="Center" />

                <Label
                    x:Name="SaveModalTimeLabel"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    TextColor="{StaticResource TextSecondary}"
                    HorizontalTextAlignment="Center" />

                <Border
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="12"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Editor
                        x:Name="SaveModalNotesEditor"
                        Placeholder="Add notes..."
                        BackgroundColor="Transparent"
                        HeightRequest="100"
                        TextColor="{StaticResource TextSecondary}"
                        PlaceholderColor="{StaticResource MutedText}" />
                </Border>

                <Button
                    Text="SAVE"
                    BackgroundColor="{StaticResource AccentNeonYellow}"
                    TextColor="#0D0D0D"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    CornerRadius="22"
                    HeightRequest="50"
                    Clicked="OnSaveModalSaveClicked" />

                <Button
                    Text="CANCEL"
                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                    TextColor="{StaticResource TextSecondary}"
                    FontFamily="OpenSansSemibold"
                    FontSize="14"
                    CornerRadius="22"
                    HeightRequest="44"
                    Clicked="OnSaveModalCancelClicked" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
