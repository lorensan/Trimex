<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.EmomConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + bento grid + summary + buttons -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="12">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="EMOM"
                    TextColor="{StaticResource TextPrimary}" />
                <Grid
                ColumnDefinitions="32,Auto,32"
                ColumnSpacing="12"
                HorizontalOptions="Center">
                    <BoxView
                    Color="{StaticResource AccentGold}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center" />
                    
                    <Label
                    x:Name="WorkoutContextLabel"
                    Grid.Column="1"
                    CharacterSpacing="3"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"
                    Text="Every Minute On the Minute"
                    TextColor="{StaticResource TextSecondary}" />
                    
                    <BoxView
                    Grid.Column="2"
                    Color="{StaticResource AccentGold}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

            <!-- Bento Grid: Duration | Rounds -->
            <Grid
                Grid.Row="1"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">

                <!-- Duration Carousel -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnDurationPanUpdated" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="5,*">
                        <BoxView
                            Grid.Column="0"
                            BackgroundColor="{StaticResource AccentRed}"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                        <VerticalStackLayout
                            Grid.Column="1"
                            HorizontalOptions="Center"
                            Spacing="1"
                            VerticalOptions="Center">
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="9"
                                HorizontalTextAlignment="Center"
                                Text="DURATION"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="DurationSlotMinus2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Opacity="0.3"
                                TextColor="{StaticResource MutedText}" />
                            <Label
                                x:Name="DurationSlotMinus1"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HorizontalTextAlignment="Center"
                                Opacity="0.5"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="DurationDisplayLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="28"
                                HorizontalTextAlignment="Center"
                                TextColor="{StaticResource AccentGold}" />
                            <Label
                                x:Name="DurationSlotPlus1"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HorizontalTextAlignment="Center"
                                Opacity="0.5"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="DurationSlotPlus2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Opacity="0.3"
                                TextColor="{StaticResource MutedText}" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="7"
                                HorizontalTextAlignment="Center"
                                Text="SWIPE"
                                TextColor="{StaticResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Rounds Carousel -->
                <Border
                    Grid.Column="1"
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnRoundsPanUpdated" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="5,*">
                        <BoxView
                            Grid.Column="0"
                            BackgroundColor="{StaticResource AccentGold}"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                        <VerticalStackLayout
                            Grid.Column="1"
                            HorizontalOptions="Center"
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="9"
                                HorizontalTextAlignment="Center"
                                Text="ROUNDS"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="RoundsSlotMinus2"
                                FontFamily="OpenSansSemibold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"
                                Opacity="0.3"
                                TextColor="{StaticResource MutedText}" />
                            <Label
                                x:Name="RoundsSlotMinus1"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalTextAlignment="Center"
                                Opacity="0.5"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="RoundsDisplayLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="36"
                                HorizontalTextAlignment="Center"
                                TextColor="{StaticResource AccentGold}" />
                            <Label
                                x:Name="RoundsSlotPlus1"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalTextAlignment="Center"
                                Opacity="0.5"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="RoundsSlotPlus2"
                                FontFamily="OpenSansSemibold"
                                FontSize="12"
                                HorizontalTextAlignment="Center"
                                Opacity="0.3"
                                TextColor="{StaticResource MutedText}" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="7"
                                HorizontalTextAlignment="Center"
                                Text="SWIPE"
                                TextColor="{StaticResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </Grid>

            <!-- Session Volume Summary Bar -->
            <Border
                Grid.Row="2"
                BackgroundColor="{StaticResource SurfaceContainerHighest}"
                Padding="14,10"
                Stroke="Transparent"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="ROUNDS"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="RoundsSummaryLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="10"
                            TextColor="{StaticResource AccentGold}" />
                    </VerticalStackLayout>
                    <BoxView
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BorderColor}"
                        HeightRequest="28"
                        VerticalOptions="Center"
                        WidthRequest="1" />
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="TOTAL TIME"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="TotalTimeSummaryLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="05:00"
                            TextColor="{StaticResource AccentGold}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <VerticalStackLayout Grid.Row="3" Spacing="10">

                <!-- Death by EMOM -->
                <Border
                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDeathByTapped" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Padding="0,16"
                        Spacing="10">
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="18"
                            Text="☠"
                            TextColor="{StaticResource AccentRed}"
                            VerticalOptions="Center" />
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="14"
                            Text="DEATH BY EMOM"
                            TextColor="{StaticResource AccentRed}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- START WORKOUT -->
                <Button
                    BackgroundColor="#CAFD00"
                    Clicked="OnStartClicked"
                    CornerRadius="14"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HeightRequest="52"
                    Text="START WORKOUT"
                    ImageSource="rayb.png"
                    ContentLayout="Right, 8"
                    TextColor="#000000" />

            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
