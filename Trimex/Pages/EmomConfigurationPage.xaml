<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.EmomConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="EMOM">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + bento grid + summary + buttons -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="12">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="EMOM"
                    TextColor="{StaticResource TextPrimary}" />
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansRegular"
                    FontSize="10"
                    HorizontalTextAlignment="Center"
                    Text="EVERY MINUTE ON THE MINUTE"
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Bento Grid: Duration | Rounds -->
            <Grid
                Grid.Row="1"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">

                <!-- Duration Card -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDurationTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="5,*">
                        <BoxView
                            Grid.Column="0"
                            BackgroundColor="{StaticResource AccentGold}"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                        <VerticalStackLayout
                            Grid.Column="1"
                            Padding="14,20"
                            Spacing="6"
                            VerticalOptions="Center">
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="9"
                                Text="DURATION"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="DurationDisplayLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="32"
                                Text="00:30"
                                TextColor="{StaticResource AccentGold}" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="8"
                                Text="TAP TO EDIT"
                                TextColor="{StaticResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Rounds Card -->
                <Border
                    Grid.Column="1"
                    BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRoundsTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="5,*">
                        <BoxView
                            Grid.Column="0"
                            BackgroundColor="{StaticResource AccentGold}"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill" />
                        <VerticalStackLayout
                            Grid.Column="1"
                            Padding="14,20"
                            Spacing="6"
                            VerticalOptions="Center">
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="9"
                                Text="ROUNDS"
                                TextColor="{StaticResource TextSecondary}" />
                            <Label
                                x:Name="RoundsDisplayLabel"
                                FontFamily="OpenSansSemibold"
                                FontSize="52"
                                Text="10"
                                TextColor="{StaticResource TextPrimary}" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="8"
                                Text="TAP TO ADJUST"
                                TextColor="{StaticResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </Grid>

            <!-- Session Volume Summary Bar -->
            <Border
                Grid.Row="2"
                BackgroundColor="{StaticResource SurfaceContainerHighest}"
                Padding="14,10"
                Stroke="Transparent"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="ROUNDS"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="RoundsSummaryLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="10"
                            TextColor="{StaticResource AccentGold}" />
                    </VerticalStackLayout>
                    <BoxView
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BorderColor}"
                        HeightRequest="28"
                        VerticalOptions="Center"
                        WidthRequest="1" />
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="TOTAL TIME"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="TotalTimeSummaryLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="05:00"
                            TextColor="{StaticResource AccentGold}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Action Buttons -->
            <VerticalStackLayout Grid.Row="3" Spacing="10">

                <!-- Death by EMOM -->
                <Border
                    BackgroundColor="{StaticResource SurfaceContainerHighest}"
                    Padding="0"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDeathByTapped" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Padding="0,16"
                        Spacing="10">
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="18"
                            Text="☠"
                            TextColor="{StaticResource AccentRed}"
                            VerticalOptions="Center" />
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="14"
                            Text="DEATH BY EMOM"
                            TextColor="{StaticResource AccentRed}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- START WORKOUT -->
                <Button
                    BackgroundColor="#CAFD00"
                    Clicked="OnStartClicked"
                    CornerRadius="14"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HeightRequest="52"
                    Text="START WORKOUT ⚡"
                    TextColor="#000000" />

            </VerticalStackLayout>

        </Grid>

        <!-- Duration overlay -->
        <Grid
            x:Name="DurationOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDurationOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Duration"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="DurationItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnDurationOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Rounds overlay -->
        <Grid
            x:Name="RoundsOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRoundsOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Rounds"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="RoundsItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnRoundsOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
