<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.DeathByEmomPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Death by EMOM">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Content centered vertically -->
        <VerticalStackLayout Padding="24,40,24,40" Spacing="18" VerticalOptions="Center">

            <Label Style="{StaticResource PageTitleStyle}" Text="EMOM" />
            <Label Style="{StaticResource HeroSubtitleStyle}" Text="Death by EMOM" />

            <!-- Duration Carousel -->
            <Border Style="{StaticResource CardBorderStyle}">
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPickerPanUpdated" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Margin="0,0,0,8"
                        Text="EACH INTERVAL"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotMinus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        x:Name="PickerSlotMinus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="DurationDisplayLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="52"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource AccentGold}" />
                    <Label
                        x:Name="PickerSlotPlus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotPlus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        Margin="0,8,0,0"
                        Text="SWIPE UP OR DOWN"
                        TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>

            <!-- START -->
            <Button
                Clicked="OnStartClicked"
                Style="{StaticResource GreenButtonStyle}"
                Text="START" />

        </VerticalStackLayout>

            </Grid>
        </ContentPage>
