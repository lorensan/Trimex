<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.DeathByEmomPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Trimex.Controls"
    BackgroundColor="{StaticResource AppBackground}"
    NavigationPage.HasNavigationBar="False">

    <Grid
        BackgroundColor="{StaticResource AppBackground}"
        RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Row 0 · Top Navigation Bar -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="48,*,48"
            HeightRequest="64"
            Padding="16,0">
            <Label
                Grid.Column="1"
                FontAttributes="Bold,Italic"
                FontFamily="OpenSansSemibold"
                FontSize="20"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="TRIMEX"
                TextColor="{StaticResource AccentNeonYellow}"
                VerticalOptions="Center" />
        </Grid>

        <!-- Row 1 · Title + Subtitle -->
        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Padding="24,0"
            Spacing="4">
            <Label
                x:Name="WorkoutTitleLabel"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                FontSize="48"
                HorizontalTextAlignment="Center"
                Text="EMOM"
                TextColor="{StaticResource TextPrimary}" />
            <Grid
                ColumnDefinitions="32,Auto,32"
                ColumnSpacing="12"
                HorizontalOptions="Center">
                <BoxView
                    Color="{StaticResource AccentGold}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center" />
                <Label
                    x:Name="WorkoutContextLabel"
                    Grid.Column="1"
                    CharacterSpacing="3"
                    FontFamily="OpenSansSemibold"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="1"
                    Text="Death by EMOM"
                    TextColor="{StaticResource TextSecondary}" />
                <BoxView
                    Grid.Column="2"
                    Color="{StaticResource AccentGold}"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Opacity="0.3"
                    VerticalOptions="Center" />
            </Grid>
        </VerticalStackLayout>

        <!-- Row 2 · Central Timer (carousel) -->
        <Grid
            Grid.Row="2"
            Padding="24,16,24,0">
            <Border
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="16"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPickerPanUpdated" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Margin="0,0,0,8"
                        Text="EACH INTERVAL"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotMinus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        x:Name="PickerSlotMinus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="DurationDisplayLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="52"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource AccentGold}" />
                    <Label
                        x:Name="PickerSlotPlus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="PickerSlotPlus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        Margin="0,8,0,0"
                        Text="SWIPE UP OR DOWN"
                        TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Row 3 · Metrics Grid (empty spacer) -->
        <Grid Grid.Row="3" Padding="24,0" />

        <!-- Row 4 · Start Button -->
        <Button
            Grid.Row="4"
            Clicked="OnStartClicked"
            BackgroundColor="{StaticResource AccentNeonYellow}"
            TextColor="#0D0D0D"
            FontFamily="OpenSansSemibold"
            FontSize="18"
            CornerRadius="22"
            HeightRequest="56"
            ImageSource="rayb.png"
            ContentLayout="Right, 8"
            Text="START WORKOUT"
            Margin="24,16,24,32" />
    </Grid>
</ContentPage>
