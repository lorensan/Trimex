<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.TabataConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="TABATA">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Content centered vertically -->
        <VerticalStackLayout Padding="24,40,24,40" Spacing="18" VerticalOptions="Center">

            <Label Style="{StaticResource PageTitleStyle}" Text="TABATA" />
            <Label Style="{StaticResource HeroSubtitleStyle}" Text="Configure your tabata as you like" />

            <!-- Rounds -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitleStyle}" Text="Rounds" />
                    <Border
                        Padding="14"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRoundsTapped" />
                        </Border.GestureRecognizers>
                        <Label
                            x:Name="RoundsDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Text="8 ROUNDS"
                            TextColor="{StaticResource TextPrimary}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Work Time -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitleStyle}" Text="Work Time" />
                    <Border
                        Padding="14"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnWorkTimeTapped" />
                        </Border.GestureRecognizers>
                        <Label
                            x:Name="WorkTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Text="20 seconds"
                            TextColor="{StaticResource AccentGreen}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Rest Time -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitleStyle}" Text="Rest Time" />
                    <Border
                        Padding="14"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRestTimeTapped" />
                        </Border.GestureRecognizers>
                        <Label
                            x:Name="RestTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Text="10 seconds"
                            TextColor="{StaticResource AccentRed}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- START -->
            <Button
                Clicked="OnStartClicked"
                Style="{StaticResource GreenButtonStyle}"
                Text="START" />

        </VerticalStackLayout>

        <!-- Rounds overlay -->
        <Grid
            x:Name="RoundsOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRoundsOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Rounds"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="RoundsItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnRoundsOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Work Time overlay -->
        <Grid
            x:Name="WorkTimeOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkTimeOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Work Time"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="WorkTimeItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnWorkTimeOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Rest Time overlay -->
        <Grid
            x:Name="RestTimeOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRestTimeOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Rest Time"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="RestTimeItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnRestTimeOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
