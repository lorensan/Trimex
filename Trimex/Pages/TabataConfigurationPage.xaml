<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.TabataConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="TABATA">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + 3 cards + stats + button -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,*,*,Auto,Auto"
            RowSpacing="10">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="TABATA"
                    TextColor="{StaticResource TextPrimary}" />
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansRegular"
                    FontSize="10"
                    HorizontalTextAlignment="Center"
                    Text="CONFIGURE YOUR TABATA AS YOU LIKE"
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Rounds Card -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="16,12"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRoundsTapped" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        Text="ROUNDS"
                        TextColor="{StaticResource TextSecondary}" />
                    <HorizontalStackLayout Spacing="6">
                        <Label
                            x:Name="RoundsNumberLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="44"
                            Text="8"
                            TextColor="{StaticResource AccentNeonYellow}"
                            VerticalOptions="End" />
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            Margin="0,0,0,4"
                            Text="SETS"
                            TextColor="{StaticResource TextSecondary}"
                            VerticalOptions="End" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Work Time Card -->
            <Border
                Grid.Row="2"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnWorkTimeTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="5,*">
                    <BoxView
                        Grid.Column="0"
                        BackgroundColor="{StaticResource AccentNeonYellow}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                    <VerticalStackLayout Grid.Column="1" Padding="16,12" Spacing="4" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="⏱"
                                TextColor="{StaticResource AccentNeonYellow}"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                Text="WORK TIME"
                                TextColor="{StaticResource TextSecondary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                            x:Name="WorkTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="36"
                            Text="00:20"
                            TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Rest Time Card -->
            <Border
                Grid.Row="3"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRestTimeTapped" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="5,*">
                    <BoxView
                        Grid.Column="0"
                        BackgroundColor="{StaticResource AccentPurple}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                    <VerticalStackLayout Grid.Column="1" Padding="16,12" Spacing="4" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="💤"
                                TextColor="{StaticResource AccentPurple}"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                Text="REST TIME"
                                TextColor="{StaticResource TextSecondary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                            x:Name="RestTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="36"
                            Text="00:10"
                            TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Total Stats Bar -->
            <Border
                Grid.Row="4"
                BackgroundColor="{StaticResource SurfaceContainerHighest}"
                Padding="14,10"
                Stroke="Transparent"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="TOTAL DURATION"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="TotalDurationLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="04:00"
                            TextColor="{StaticResource AccentNeonYellow}" />
                    </VerticalStackLayout>
                    <BoxView
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BorderColor}"
                        HeightRequest="28"
                        VerticalOptions="Center"
                        WidthRequest="1" />
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="INTENSITY"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="MAX"
                            TextColor="{StaticResource AccentPurple}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- START WORKOUT -->
            <Button
                Grid.Row="5"
                BackgroundColor="{StaticResource AccentNeonYellow}"
                Clicked="OnStartClicked"
                CornerRadius="14"
                FontFamily="OpenSansSemibold"
                FontSize="16"
                HeightRequest="52"
                Text="START WORKOUT ⚡"
                TextColor="#0D0D0D" />

        </Grid>

        <!-- Rounds overlay -->
        <Grid
            x:Name="RoundsOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRoundsOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Rounds"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="RoundsItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnRoundsOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Work Time overlay -->
        <Grid
            x:Name="WorkTimeOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWorkTimeOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Work Time"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="WorkTimeItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnWorkTimeOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Rest Time overlay -->
        <Grid
            x:Name="RestTimeOverlay"
            BackgroundColor="{StaticResource Overlay}"
            IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRestTimeOverlayBackgroundTapped" />
            </Grid.GestureRecognizers>
            <Border
                Padding="20"
                BackgroundColor="{StaticResource Surface}"
                HeightRequest="300"
                HorizontalOptions="Center"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1"
                VerticalOptions="Center"
                WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Label
                        Grid.Row="0"
                        FontFamily="OpenSansSemibold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Select Rest Time"
                        TextColor="{StaticResource TextPrimary}" />
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout
                            x:Name="RestTimeItemsLayout"
                            HorizontalOptions="Center"
                            Spacing="4" />
                    </ScrollView>
                    <Button
                        Grid.Row="2"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        Clicked="OnRestTimeOverlayCancelClicked"
                        CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        HeightRequest="44"
                        Text="Cancel"
                        TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
