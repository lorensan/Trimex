<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trimex.Pages.TabataConfigurationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="TABATA">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" InputTransparent="True" />

        <!-- Full-screen fit layout: header + 3 cards + stats + button -->
        <Grid
            Padding="20,40,20,24"
            RowDefinitions="Auto,*,*,*,Auto,Auto"
            RowSpacing="10">

            <!-- Hero Header -->
            <VerticalStackLayout Grid.Row="0" Margin="0,0,0,4" Spacing="2">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="38"
                    HorizontalTextAlignment="Center"
                    Text="TABATA"
                    TextColor="{StaticResource TextPrimary}" />
                <Label
                    CharacterSpacing="2"
                    FontFamily="OpenSansRegular"
                    FontSize="10"
                    HorizontalTextAlignment="Center"
                    Text="CONFIGURE YOUR TABATA AS YOU LIKE"
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Rounds Carousel -->
            <Border
                Grid.Row="1"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnRoundsPanUpdated" />
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="10"
                        HorizontalTextAlignment="Center"
                        Text="ROUNDS"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="RoundsSlotMinus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        x:Name="RoundsSlotMinus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="RoundsNumberLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="36"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource AccentNeonYellow}" />
                    <Label
                        x:Name="RoundsSlotPlus1"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        HorizontalTextAlignment="Center"
                        Opacity="0.5"
                        TextColor="{StaticResource TextSecondary}" />
                    <Label
                        x:Name="RoundsSlotPlus2"
                        FontFamily="OpenSansSemibold"
                        FontSize="12"
                        HorizontalTextAlignment="Center"
                        Opacity="0.3"
                        TextColor="{StaticResource MutedText}" />
                    <Label
                        CharacterSpacing="2"
                        FontFamily="OpenSansSemibold"
                        FontSize="8"
                        HorizontalTextAlignment="Center"
                        Text="SWIPE UP OR DOWN"
                        TextColor="{StaticResource MutedText}" />
                </VerticalStackLayout>
            </Border>

            <!-- Work Time Carousel -->
            <Border
                Grid.Row="2"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnWorkPanUpdated" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="5,*">
                    <BoxView
                        Grid.Column="0"
                        BackgroundColor="{StaticResource AccentNeonYellow}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="⏱"
                                TextColor="{StaticResource AccentNeonYellow}"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                Text="WORK TIME"
                                TextColor="{StaticResource TextSecondary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                            x:Name="WorkSlotMinus2"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            Opacity="0.3"
                            TextColor="{StaticResource MutedText}" />
                        <Label
                            x:Name="WorkSlotMinus1"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Opacity="0.5"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="WorkTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="36"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource AccentNeonYellow}" />
                        <Label
                            x:Name="WorkSlotPlus1"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Opacity="0.5"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="WorkSlotPlus2"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            Opacity="0.3"
                            TextColor="{StaticResource MutedText}" />
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="8"
                            HorizontalTextAlignment="Center"
                            Text="SWIPE UP OR DOWN"
                            TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Rest Time Carousel -->
            <Border
                Grid.Row="3"
                BackgroundColor="{StaticResource SurfaceContainerLow}"
                Padding="0"
                Stroke="{StaticResource BorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnRestPanUpdated" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="5,*">
                    <BoxView
                        Grid.Column="0"
                        BackgroundColor="{StaticResource AccentPurple}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="💤"
                                TextColor="{StaticResource AccentPurple}"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2"
                                FontFamily="OpenSansSemibold"
                                FontSize="10"
                                Text="REST TIME"
                                TextColor="{StaticResource TextSecondary}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                            x:Name="RestSlotMinus2"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            Opacity="0.3"
                            TextColor="{StaticResource MutedText}" />
                        <Label
                            x:Name="RestSlotMinus1"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Opacity="0.5"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="RestTimeDisplayLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="36"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource AccentPurple}" />
                        <Label
                            x:Name="RestSlotPlus1"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Opacity="0.5"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="RestSlotPlus2"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            HorizontalTextAlignment="Center"
                            Opacity="0.3"
                            TextColor="{StaticResource MutedText}" />
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="8"
                            HorizontalTextAlignment="Center"
                            Text="SWIPE UP OR DOWN"
                            TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Total Stats Bar -->
            <Border
                Grid.Row="4"
                BackgroundColor="{StaticResource SurfaceContainerHighest}"
                Padding="14,10"
                Stroke="Transparent"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="TOTAL DURATION"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            x:Name="TotalDurationLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="04:00"
                            TextColor="{StaticResource AccentNeonYellow}" />
                    </VerticalStackLayout>
                    <BoxView
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BorderColor}"
                        HeightRequest="28"
                        VerticalOptions="Center"
                        WidthRequest="1" />
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                        <Label
                            CharacterSpacing="2"
                            FontFamily="OpenSansSemibold"
                            FontSize="9"
                            HorizontalTextAlignment="Center"
                            Text="INTENSITY"
                            TextColor="{StaticResource TextSecondary}" />
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="MAX"
                            TextColor="{StaticResource AccentPurple}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- START WORKOUT -->
            <Button
                Grid.Row="5"
                BackgroundColor="{StaticResource AccentNeonYellow}"
                Clicked="OnStartClicked"
                CornerRadius="14"
                FontFamily="OpenSansSemibold"
                FontSize="16"
                HeightRequest="52"
                Text="START WORKOUT ⚡"
                TextColor="#0D0D0D" />

        </Grid>
    </Grid>
</ContentPage>
