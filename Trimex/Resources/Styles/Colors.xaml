<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="AppBackground">#0D0D0D</Color>
    <Color x:Key="Surface">#161616</Color>
    <Color x:Key="SurfaceAlt">#202020</Color>
    <Color x:Key="BorderColor">#2E2E2E</Color>
    <Color x:Key="AccentRed">#FF3B3B</Color>
    <Color x:Key="AccentBlue">#423BFF</Color>
    <Color x:Key="AccentGold">#FFD166</Color>
    <Color x:Key="AccentGreen">#35D07F</Color>
    <Color x:Key="AccentPurple">#9B5DE5</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B8B8B8</Color>
    <Color x:Key="MutedText">#8A8A8A</Color>
    <Color x:Key="Overlay">#CC0D0D0D</Color>
    <Color x:Key="AccentNeonYellow">#CAFD00</Color>
    <Color x:Key="SurfaceContainerLow">#131313</Color>
    <Color x:Key="SurfaceContainerHighest">#262626</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAlt}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}" />
</ResourceDictionary>
